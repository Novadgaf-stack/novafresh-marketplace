{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role store",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "vendor", "admin"] }
      },
      "required": ["role"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Marketplace asset listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "inventory": { "type": "number" },
        "rating": { "type": "number" },
        "image": { "type": "string" }
      },
      "required": ["name", "price", "image", "category"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user identity and roles."
    },
    "/assets/{assetId}": {
      "schema": { "$ref": "#/entities/Asset" },
      "description": "Stores the marketplace asset catalogue."
    }
  }
}
